// datasource configures the database connection engine to your MySQL instance
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// generator specifies the generation environment for the type-safe Prisma Client
generator client {
  provider = "prisma-client-js" // ◄ Fixed copy-paste typo here
}

// ==========================================
// 1. IDENTITY & USER ROLES MODULE
// ==========================================

enum UserRole {
  STUDENT
  STAFF
  LECTURER
  ADMIN
}

enum Department {
  REGISTRAR
  FINANCE
  FACULTY_HOD
  CAMPUS_OPERATIONS
  ESTATE_MANAGEMENT
  GENERAL_SUPPORT

  COMPUTER_SCIENCE
  SOFTWARE_ENGINEERING
  CIVIL_ENGINEERING
  BUSINESS_ADMINISTRATION
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  phoneNumber   String          @unique
  passwordHash  String          // Securely managed via bcrypt on the NestJS backend
  fullName      String
  role          UserRole        @default(STUDENT)
  department    Department?     // Nullable because students don't belong to an administrative desk
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  ticketsSubmitted Ticket[]      @relation("StudentTickets")
  ticketsProcessed TicketHistory[] @relation("StaffActions")

  @@index([email])
}

// ==========================================
// 2. ISSUE TRACKING & LEDGER MODULE
// ==========================================

enum IssueCategory {
  ACADEMIC_PROGRESSION_VERIFICATION
  ADMINISTRATIVE_OPERATIONAL_REQUESTS
  FINANCIAL_GATEWAYS
  DIRECT_SUPPORT_EXTERNAL_COMPLIANCE
}

enum TicketStatus {
  SUBMITTED
  UNDER_REVIEW
  ACTION_REQUIRED
  APPROVED
  RESOLVED
  REJECTED
}
 
// schema.prisma (Issue Tracking Section)
model Ticket {
  id              String         @id @default(uuid())
  trackingCode    String         @unique 
  studentId       String
  isInternational Boolean        @default(false)
  category        IssueCategory
  serviceName     String          
  description     String         @db.Text
  status          TicketStatus   @default(SUBMITTED)
  
  // ◄ ADD THESE 3 NEW SCHEDULING PARAMS HERE:
  assessmentDate  DateTime?      // Stores the scheduled time slot for makeups
  assessmentVenue String?        // Stores physical location parameters (e.g., "Lab 3")
  lecturerNotes   String?        @db.Text // Holds optional context or instructions

  isMarkAltered   Boolean?      // true if marks were updated, false if confirmed valid
  revisedMarkInfo String?       // e.g., "CAT 1 changed from 12/20 to 17/20. Final: 65%"
  hodAuditNotes   String?       @db.Text // Contextual feedback from checking the book sheet

  generatedTranscriptUrl  String?
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  student         User           @relation("StudentTickets", fields: [studentId], references: [id], onDelete: Cascade)
  attachments     Attachment[]
  history         TicketHistory[]

  @@index([trackingCode])
  @@index([status])
  @@index([category])
}

// ==========================================
// 3. EVIDENCE & ATTACHMENT PIPELINE
// ==========================================

model Attachment {
  id          String   @id @default(uuid())
  ticketId    String
  fileUrl     String   // Destination storage bucket link (e.g., failed payment screenshots, medical notes)
  fileName    String
  uploadedAt  DateTime @default(now())

  // Relations
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

// ==========================================
// 4. HISTORICAL LOGGING & AUDIT TRAIL
// ==========================================

model TicketHistory {
  id            String       @id @default(uuid())
  ticketId      String
  staffId       String?      // Can be null if system automated transitions happen
  previousState TicketStatus
  newState      TicketStatus
  comment       String?      @db.Text // Mandatory message if changing status to ACTION_REQUIRED
  changedAt     DateTime     @default(now())

  // Relations
  ticket        Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  staff         User?        @relation("StaffActions", fields: [staffId], references: [id])

  @@index([ticketId])
}